<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".NavigationActivity"
    tools:ignore="VisualLintBounds">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/my_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorSecondary"
        android:elevation="4dp"
        app:navigationIcon="@drawable/ic_back_arrow"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
        app:title="Campus Navigation"
        app:titleTextColor="?android:attr/textColorSecondary" />

    <!-- Search Bar with Button -->
    <RelativeLayout
        android:id="@+id/search_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/my_toolbar"
        android:layout_margin="12dp">

        <EditText
            android:id="@+id/search_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginEnd="48dp"
            android:layout_toStartOf="@+id/btn_search"
            android:background="@android:drawable/edit_text"
            android:hint="@string/search_for_building_or_area"
            android:importantForAutofill="no"
            android:padding="12dp"
            android:textColor="#000000"
            android:textColorHint="#757575"
            tools:ignore="TextFields,VisualLintTextFieldSize" />

        <ImageButton
            android:id="@+id/btn_search"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignTop="@id/search_location"
            android:layout_alignBottom="@id/search_location"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="4dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/search"
            android:padding="4dp"
            android:src="@android:drawable/ic_menu_search"
            app:tint="?android:attr/textColorPrimary"
            tools:ignore="TouchTargetSizeCheck" />
    </RelativeLayout>

    <!-- Google Map -->
    <com.google.android.gms.maps.MapView
        android:id="@+id/campus_map"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:layout_below="@id/search_container"
        android:layout_marginTop="16dp"
        android:contentDescription="@string/map_showing_metro_and_bus_stop_locations_for_south_campus" />

    <!-- List of Locations -->
    <ListView
        android:id="@+id/building_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/bottom_navigation"
        android:layout_below="@id/campus_map"
        android:layout_marginTop="8dp"
        android:divider="@android:color/darker_gray"
        android:dividerHeight="1dp" />

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        app:menu="@menu/bottom_nav_menu"
        app:itemActiveIndicatorStyle="@style/NoActiveIndicatorStyle"
        android:background="?android:attr/windowBackground"
        tools:ignore="VisualLintBottomNav" />

</RelativeLayout>
